# PostgreSQL connection string (Neon)
# Get yours at https://neon.tech
DATABASE_URL="postgresql://username:password@ep-your-endpoint.region.aws.neon.tech/neondb?sslmode=require"

# Google Gemini API Key — get yours free at https://aistudio.google.com
GEMINI_API_KEY="your-gemini-api-key-here"

# Auth.js Configuration
# Generate a secret key using: npx auth secret (or openssl rand -base64 33)
AUTH_SECRET="your-auth-secret-here"
# The base URL of your site (e.g., http://localhost:3000 for local development)
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare Turnstile CAPTCHA (Free bot prevention)
# Get keys at: https://dash.cloudflare.com/ (Turnstile tab)
# Fallback to public testing keys in development:
# Site Key: 1x00000000000000000000AA (always passes, safe to share)
# Secret Key: 1x00000000000000000000000000000000AA (always passes, keep private)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x00000000000000000000000000000000AA"

